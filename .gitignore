# Rust build artifacts (Cargo.lock IS committed -- trizaval-cli is a
# binary, and reproducible builds matter more than lockfile churn)
/target/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
build/
dist/
crates/trizaval-py/target/
crates/trizaval-py/.venv/


# Compiled PyO3 extension module -- platform/Python-version-specific
# build output from `maturin develop`, regenerated by CI and by
# anyone building locally, never committed as source.
*.so
*.pyd

# WASM build output -- regenerated from crates/trizaval-wasm source
# via `wasm-pack build`, never committed as a binary artifact.
dashboard/wasm/
dashboard/node_modules/
dashboard/dist/

# Editor/OS noise
.vscode/
.idea/
*.swp
.DS_Store

.env
.env.*

# pytest cache
.pytest_cache/

# Personal working notes, not part of the shipped project
Full-Tree.tree